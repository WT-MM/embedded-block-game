%% Source: hw/soc_system.qsys (Platform Designer module + connection
%% list). soc_system.v is generated by qsys-generate and is NOT in
%% the repo; the .qsys file is authoritative.
flowchart LR
    classDef hps fill:#fde2c4,stroke:#b06000,color:#3a2200;
    classDef pll fill:#fff1a8,stroke:#806400,color:#231a00;
    classDef sdram fill:#d2f4d2,stroke:#1f6b1f,color:#0c2c0c;
    classDef gpu fill:#cfe9ff,stroke:#1f4d7a,color:#0c2138;
    classDef clk fill:#cfd8dc,stroke:#37474f,color:#0f1a20;

    CLK["clk_0<br/>kind=clock_source<br/>50 MHz"]:::clk
    SDRAMPLL["sdram_clocks<br/>kind=altera_up_avalon_sys_sdram_pll"]:::pll
    HPS["hps_0<br/>kind=altera_hps (v19.1)"]:::hps
    GPU["voxel_gpu_0<br/>kind=voxel_gpu (v1.0)"]:::gpu
    SDRAMC["fpga_sdram<br/>kind=altera_avalon_new_sdram_controller"]:::sdram

    CLK -- clock --> SDRAMPLL
    SDRAMPLL -- sys_clk --> SDRAMC
    SDRAMPLL -- sys_clk --> HPS
    SDRAMPLL -- sys_clk --> GPU
    SDRAMPLL -- sdram_clk --> SDRAMC

    HPS -- "h2f_axi_master (avalon)" --> SDRAMC
    HPS -- "h2f_lw_axi_master (avalon)" --> GPU

    %% Conduits exported to soc_system_top.sv pins:
    HPS -. hps_io / memory .-> HPSIO["hps pin set,<br/>DDR3"]:::hps
    GPU -. vga conduit .-> VGAOUT["VGA_R/G/B + HS/VS"]:::gpu
    GPU -. voxel_sdram conduit .-> DRAM["Board SDR SDRAM<br/>(via Sdram_Control inside voxel_gpu)"]:::sdram
