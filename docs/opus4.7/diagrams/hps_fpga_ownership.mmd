%% Source: sw/* (HPS side), hw/voxel_gpu/rtl/* (FPGA side),
%% hw/soc_system.qsys connections, sw/voxel_gpu.h register map.
flowchart LR
    classDef hps fill:#fde2c4,stroke:#b06000,color:#3a2200;
    classDef fpga fill:#cfe9ff,stroke:#1f4d7a,color:#0c2138;
    classDef shared fill:#fff1a8,stroke:#806400,color:#231a00;

    subgraph HPS["HPS responsibilities"]
        direction TB
        H1["Game state + world chunks<br/>sw/world.c, world_gen.c"]
        H2["Mesh + cull<br/>sw/mesh_worker.c"]
        H3["Build per-quad descriptors<br/>(quad_desc, quad_desc_uv)<br/>sw/renderer.c"]
        H4["Bin descriptors by 60-line band<br/>sw/gpu_transport.c"]
        H5["Stream FIFO_WINDOW writes<br/>sw/voxel_gpu.c (iowrite32_rep)"]
        H6["Sky palette + fog upload<br/>VOXEL_IOC_SET_SKY_PALETTE,<br/>VOXEL_IOC_SET_FOG"]
        H1 --> H2 --> H3 --> H4 --> H5
        H3 --> H6
    end
    class HPS hps

    subgraph BUS["Shared / boundary"]
        direction TB
        B1["Avalon-MM lwslave<br/>(13-bit word addr, 32 b data)"]
        B2["/dev/voxel_gpu misc device"]
        B3["SDR SDRAM (double FB, RGB565)"]
    end
    class BUS shared

    subgraph FPGA["FPGA responsibilities"]
        direction TB
        F1["FIFO 1024x32 (M10K)"]
        F2["Descriptor decode + ST_FETCH"]
        F3["Edge / Z / UV rasterizer<br/>voxel_raster_setup + voxel_draw_step"]
        F4["Per-pixel 1/w + UV<br/>voxel_iw_normalize -><br/>voxel_recip_interpolate -><br/>voxel_w_denormalize"]
        F5["Texture ROM lookup<br/>voxel_texture_rom"]
        F6["Palette + fog + alpha blend<br/>voxel_fog_blend"]
        F7["Band cache writes<br/>fb_back_ram_A/B, z_ram_A/B"]
        F8["Background flush -> SDRAM<br/>Sdram_Control"]
        F9["VGA scanout<br/>voxel_vga_counters"]
        F1 --> F2 --> F3 --> F4 --> F5 --> F6 --> F7 --> F8 --> F9
    end
    class FPGA fpga

    H5 --> B1 --> F1
    H6 --> B1
    H4 -. ioctls .-> B2 --> B1
    F8 --> B3
    B3 -. scanout .-> F9
