%% Source: hw/soc_system.qsys, hw/soc_system_top.sv, hw/voxel_gpu_hw.tcl,
%% sw/voxel_gpu.c, sw/voxel_gpu.h. Cyclone V SoC (5CSEMA5F31C6).
flowchart LR
    classDef hps fill:#fde2c4,stroke:#b06000,color:#3a2200;
    classDef fpga fill:#cfe9ff,stroke:#1f4d7a,color:#0c2138;
    classDef mem fill:#d2f4d2,stroke:#1f6b1f,color:#0c2c0c;
    classDef io fill:#cfd8dc,stroke:#37474f,color:#0f1a20;
    classDef sw fill:#fff1a8,stroke:#806400,color:#231a00;

    subgraph SOC["Cyclone V SoC (5CSEMA5F31C6)"]
        direction LR
        subgraph HPS["HPS (ARM Cortex-A9, dual-core)"]
            direction TB
            APP["sw/game.c<br/>+ renderer.c"]
            TR["sw/gpu_transport.c<br/>(userspace transport)"]
            KMOD["sw/voxel_gpu.c<br/>(platform driver, /dev/voxel_gpu)"]
            APP --> TR --> KMOD
            class APP,TR sw
            class KMOD sw
        end
        subgraph FAB["FPGA fabric"]
            direction TB
            VGPU["voxel_gpu<br/>hw/voxel_gpu/rtl/voxel_gpu.sv"]
            VGA["VGA timing<br/>voxel_vga_counters"]
            SDC["Sdram_Control<br/>(SDR SDRAM ctrl)"]
            VGPU --> VGA
            VGPU --> SDC
            class VGPU,VGA,SDC fpga
        end
        class HPS hps
        class FAB fpga
    end

    HPS_DDR3[("HPS DDR3<br/>(via hps_0.memory)")]:::mem
    SDRAM[("Board SDR SDRAM<br/>(double framebuffer<br/>RGB565)")]:::mem
    VGA_OUT["VGA DAC -> monitor"]:::io
    HID["USB keyboard/mouse"]:::io

    KMOD -- "Avalon-MM lwslave<br/>(hps_0.h2f_lw_axi_master)" --> VGPU
    HPS -. HPS DDR3 .- HPS_DDR3
    SDC -- "DRAM_ADDR/DQ/...<br/>conduit" --> SDRAM
    VGA -- "VGA_R/G/B + HS/VS<br/>conduit" --> VGA_OUT
    HID --> APP
