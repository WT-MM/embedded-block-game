%% Source: sw/voxel_gpu.h (byte offsets), hw/voxel_gpu/rtl/voxel_gpu.sv
%% (ADDR_* word-address localparams), sw/voxel_gpu.c (ioctl handlers).
flowchart LR
    classDef sw fill:#fff1a8,stroke:#806400,color:#231a00;
    classDef ioctl fill:#dcd0ff,stroke:#553a99,color:#1d124d;
    classDef reg fill:#cfe9ff,stroke:#1f4d7a,color:#0c2138;
    classDef act fill:#d2f4d2,stroke:#1f6b1f,color:#0c2c0c;

    subgraph SW["User-space (sw/gpu_transport.c)"]
        SUBMIT["submit band: BEGIN/END_BAND"]
        FLIPSW["flip frame"]
        PALSW["palette upload"]
        FOGSW["fog config"]
        EXTSW["extmem config"]
        STSW["status / perf read"]
    end
    class SUBMIT,FLIPSW,PALSW,FOGSW,EXTSW,STSW sw

    subgraph IOCTL["ioctls (sw/voxel_gpu.c)"]
        IBB["VOXEL_IOC_BEGIN_BAND"]
        IEB["VOXEL_IOC_END_BAND"]
        IFL["VOXEL_IOC_FLIP / FLIP_ASYNC / WAIT_FLIP"]
        IPL["VOXEL_IOC_SET_PALETTE / SET_SKY_PALETTE"]
        IFO["VOXEL_IOC_SET_FOG"]
        IEX["VOXEL_IOC_SET_EXTMEM / GET_EXTMEM"]
        IST["VOXEL_IOC_GET_STATUS / GET_PERF / GET_PERF2"]
        ICLR["VOXEL_IOC_CLEAR_FRAME"]
    end
    class IBB,IEB,IFL,IPL,IFO,IEX,IST,ICLR ioctl

    subgraph REG["voxel_gpu CSRs (word addrs in RTL)"]
        R_CTRL["0x000 CONTROL EN/FLP/IEN/CLR"]
        R_STAT["0x001 STATUS BSY/FFL/FEM/VSY/FIFO_COUNT"]
        R_FCNT["0x002 FRAME_COUNT"]
        R_PAL["0x003/0x004 PALETTE_ADDR/DATA"]
        R_FOG["0x005/0x006 FOG_RANGE/FOG_CTRL"]
        R_EXT["0x007-0x00C EXTMEM_*"]
        R_BAND["0x00D-0x00F BAND_INDEX/CTRL/WINDOW"]
        R_PERF["0x010-0x019 PERF_*"]
        R_SKY["0x01A/0x01B SKY_PAL_ADDR/DATA"]
        R_FIFO["0x400-0x7FF FIFO_WINDOW (4 KB)"]
    end
    class R_CTRL,R_STAT,R_FCNT,R_PAL,R_FOG,R_EXT,R_BAND,R_PERF,R_SKY,R_FIFO reg

    SUBMIT --> IBB --> R_BAND
    SUBMIT -- "write(2) into FIFO" --> R_FIFO
    SUBMIT --> IEB --> R_BAND
    FLIPSW --> IFL --> R_CTRL
    PALSW --> IPL --> R_PAL
    PALSW --> IPL --> R_SKY
    FOGSW --> IFO --> R_FOG
    EXTSW --> IEX --> R_EXT
    STSW --> IST --> R_STAT
    STSW --> IST --> R_PERF
    STSW --> IST --> R_FCNT
    FLIPSW --> ICLR --> R_CTRL

    R_FIFO --> ACT_FETCH["ST_FETCH desc assembler"]:::act
    R_CTRL --> ACT_FSM["engine FSM control"]:::act
    R_BAND --> ACT_FSM
    R_FOG --> ACT_BLEND["voxel_fog_blend"]:::act
    R_PAL --> ACT_PAL["palette[256]"]:::act
    R_SKY --> ACT_SKY["sky_palette[24]"]:::act
    R_EXT --> ACT_SDR["Sdram_Control / scanout"]:::act
